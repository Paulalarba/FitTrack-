@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<main class="container d-flex flex-column justify-content-center align-items-center min-vh-100 px-4 py-3">
    <div class="auth-card w-100">
        <section class="text-center mb-4">
            <span class="eyebrow">Welcome Back</span>
            <h2 class="hero-title mt-3">Sign In to FitTrack</h2>
            <p class="text-secondary mb-0">Use your admin or member account to continue.</p>
        </section>

        <form asp-action="Login" method="post" class="vstack gap-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div class="cyber-group text-start">
                <label asp-for="Email" class="cyber-label"></label>
                <input asp-for="Email" class="cyber-input" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="cyber-group text-start">
                <label asp-for="Password" class="cyber-label"></label>
                <input asp-for="Password" class="cyber-input" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label text-secondary"></label>
            </div>

            <button class="btn-fit-green w-100" type="submit">Access Dashboard</button>

            <div class="d-flex justify-content-between align-items-center px-1">
                <span class="text-secondary small">New member?</span>
                <a asp-action="SignUp" class="login-link fw-bold">Create Account</a>
            </div>
        </form>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
