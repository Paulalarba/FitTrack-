@{
    ViewData["Title"] = "Commander Access";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitTrack+</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/Login.css" asp-append-version="true" />
</head>
<body class="bg-black text-white overflow-x-hidden">

    <header class="cyber-header">
        <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
            <span class="material-symbols-outlined header-close">close</span>
        </a>
        <h1 class="logo-text">FITTRACK</h1>
        <div style="width: 24px;"></div>
    </header>

    <main class="container d-flex flex-column justify-content-center align-items-center min-vh-100 px-4 py-5">
        
        <div class="w-100" style="max-width: 400px;">
            <section class="text-center mb-5">
                <h2 class="hero-title display-6">Let's sign in</h2>
            </section>

            <form asp-controller="Account" asp-action="Login" method="post" class="vstack gap-2">
                
                <div class="cyber-group text-start">
                    <label class="cyber-label">Email</label>
                    <input name="Email" class="cyber-input" type="email"  required autocomplete="email" />
                </div>

                <div class="cyber-group text-start">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="cyber-label mb-0">Access Key</label>
                        <a href="#" class="forgot-link">Forgot?</a>
                    </div>
                    <div class="position-relative">
                        <input name="Password" class="cyber-input pe-5" type="password" placeholder="••••••••••••" required />
                    </div>
                </div>

                <div class="mt-4 vstack gap-3">
                    <button class="btn-fit-green w-100" type="submit">
                        Access Dashboard <span class="material-symbols-outlined ms-2">bolt</span>
                    </button>

                    <div class="d-flex justify-content-between align-items-center mt-2 px-1">
                        <span class="text-secondary small">New here?</span>
                        <a asp-controller="Account" asp-action="SignUp" class="login-link fw-bold">Register Account</a>
                    </div>

                    <div class="d-flex align-items-center gap-3 my-2">
                        <hr class="flex-grow-1 opacity-25 border-secondary">
                        <span class="text-secondary tracking-widest uppercase" style="font-size: 9px;">OR</span>
                        <hr class="flex-grow-1 opacity-25 border-secondary">
                    </div>

                    <div class="vstack gap-2">
                        <button class="btn-social google border-0" type="button">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" width="10" />
                            <span>Google</span>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </main>

    <div class="flare flare-1"></div>
    <div class="flare flare-2"></div>
</body>
</html>