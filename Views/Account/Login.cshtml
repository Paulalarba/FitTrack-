@{
    ViewData["Title"] = "Commander Access";
}

<main class="container d-flex flex-column justify-content-center align-items-center min-vh-100 px-4 py-3">
    <div class ="w-100" style="max-width: 450px;">
        <section class="text-center mb-5">
            <h2 class="hero-title">Let's sign in</h2>
        </section>

        <form asp-controller="Account" asp-action="Login" method="post" class="vstack gap-4">
            
            <!-- Email Field -->
            <div class="cyber-group text-start">
                <label class="cyber-label">Email</label>
                <input name="Email" class="cyber-input" type="email" required autocomplete="email" />
            </div>

            <!-- Password Field -->
            <div class="cyber-group text-start">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label class="cyber-label mb-0">Password</label>
                    <a href="#" class="login-link" style="font-size: 12px;">Forgot?</a>
                </div>
                <input name="Password" class="cyber-input" type="password" required placeholder="••••••••••••" />
            </div>

            <div class="vstack gap-3 mt-2">
                <button class="btn-fit-green w-100" type="submit">
                    Access Dashboard <span class="material-symbols-outlined ms-2">bolt</span>
                </button>

                <div class="d-flex justify-content-between align-items-center mt-2 px-1">
                    <span class="text-secondary small">New here?</span>
                    <a asp-controller="Account" asp-action="SignUp" class="login-link fw-bold">Register Account</a>
                </div>

                <!-- Divider -->
                <div class="d-flex align-items-center gap-3 my-2">
                    <hr class="flex-grow-1 opacity-25 border-secondary">
                    <span class="text-secondary tracking-widest text-uppercase" style="font-size: 9px;">OR</span>
                    <hr class="flex-grow-1 opacity-25 border-secondary">
                </div>

                <!-- Social Login -->
                <button class="btn btn-light rounded-pill w-100 d-flex align-items-center justify-content-center gap-2 py-2" type="button">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" width="18" />
                    <span class="fw-bold text-dark" style="font-size: 0.9rem;">Google</span>
                </button>
            </div>
        </form>
    </div>
</main>
