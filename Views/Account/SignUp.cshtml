@{
    ViewData["Title"] = "Sign Up";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - FitTrack+</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/SignUp.css" asp-append-version="true" />
</head>
<body>

    <header class="cyber-header">
        <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
            <span class="material-symbols-outlined header-close">close</span>
        </a>
        <h1 class="logo-text">FITTRACK</h1>
        <div style="width: 24px;"></div>
    </header>

    <main class="container d-flex flex-column justify-content-center min-vh-100 py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-8 col-md-6 col-lg-4 text-center">
                
                <section class="mb-5">
                    <h2 class="hero-title display-6">Create Account</h2>
                </section>

                <form asp-controller="Account" asp-action="SignUp" method="post">
                    <div class="cyber-group text-start">
                        <label class="cyber-label">Full Name</label>
                        <input name="FullName" class="cyber-input" type="text" required autocomplete="name" />
                    </div>

                    <div class="cyber-group text-start">
                        <label class="cyber-label">Email</label>
                        <input name="Email" class="cyber-input" type="email" required autocomplete="email" />
                    </div>

                    <div class="cyber-group text-start">
                        <label class="cyber-label">Password</label>
                        <input name="Password" class="cyber-input" type="password" required placeholder="••••••••" />
                    </div>

                    <div class="mt-5">
                        <button class="btn-register" type="submit">
                            Register <span class="material-symbols-outlined ms-2">bolt</span>
                        </button>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="text-secondary small">Already have an account?</span>
                            <a asp-controller="Account" asp-action="Login" class="login-link fw-bold">Login</a>
                        </div>
                        <p class="terms-text mt-4">
                            By registering, you agree to our <br />
                            <a href="#">Protocol Terms</a> &amp; <a href="#">Privacy Policy</a>
                        </p>

                    </div>
                </form>
            </div>
        </div>
    </main>

    <div class="flare flare-1"></div>
    <div class="flare flare-2"></div>

</body>
</html>