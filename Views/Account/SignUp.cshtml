@model RegisterViewModel

@{
    ViewData["Title"] = "Sign Up";
}

<main class="container d-flex flex-column justify-content-center align-items-center min-vh-100 px-4 py-3">
    <div class="auth-card auth-card-wide w-100">
        <section class="text-center mb-4">
            <span class="eyebrow">Member Registration</span>
            <h2 class="hero-title mt-3" style="font-size:1.8rem;">Create Your Account</h2>
            <p class="text-secondary mb-0">Join FitTrack to manage your membership and payment history.</p>
        </section>

        <form asp-action="SignUp" method="post" class="row g-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small col-12"></div>

            <div class="col-md-6">
                <label asp-for="FullName" class="cyber-label"></label>
                <input asp-for="FullName" class="cyber-input" autocomplete="name" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="cyber-label"></label>
                <input asp-for="PhoneNumber" class="cyber-input" autocomplete="tel" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Email" class="cyber-label"></label>
                <input asp-for="Email" class="cyber-input" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Password" class="cyber-label"></label>
                <input asp-for="Password" class="cyber-input" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ConfirmPassword" class="cyber-label"></label>
                <input asp-for="ConfirmPassword" class="cyber-input" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button id="registerBtn" class="btn-fit-green w-100" type="submit"
                    onclick="this.disabled=true; this.form.submit();">
                Register Account
            </button>


            <div class="col-12 d-flex justify-content-between align-items-center px-1">
                <span class="text-secondary small">Already registered?</span>
                <a asp-action="Login" class="login-link fw-bold">Login Now</a>
            </div>
        </form>
    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
