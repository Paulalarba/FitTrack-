@{
    ViewData["Title"] = "Sign Up";
}

<main class="container d-flex flex-column justify-content-center align-items-center min-vh-100 px-4 py-3">
    <div class="w-100" style="max-width: 450px;">
        <section class="text-center mb-5">
            <h2 class="hero-title">Create Account</h2>
        </section>

        <form asp-controller="Account" asp-action="SignUp" method="post" class="vstack gap-4">
            
            <!-- Full Name -->
            <div class="cyber-group text-start">
                <label class="cyber-label">Full Name</label>
                <input name="FullName" class="cyber-input" type="text" required autocomplete="name" />
            </div>

            <!-- Email -->
            <div class="cyber-group text-start">
                <label class="cyber-label">Email</label>
                <input name="Email" class="cyber-input" type="email" required autocomplete="email" />
            </div>

            <!-- Password -->
            <div class="cyber-group text-start">
                <label class="cyber-label">Password</label>
                <input name="Password" class="cyber-input" type="password" required placeholder="••••••••" />
            </div>

            <div class="mt-4 vstack gap-3">
                <button class="btn-fit-green w-100" type="submit">
                    Register <span class="material-symbols-outlined ms-2">bolt</span>
                </button>

                <div class="d-flex justify-content-between align-items-center mt-2 px-1">
                    <span class="text-secondary small">Already have an account?</span>
                    <a asp-controller="Account" asp-action="Login" class="login-link fw-bold">Login Now</a>
                </div>

                <p class="text-center text-secondary" style="font-size: 10px; text-transform: uppercase; line-height: 1.6; letter-spacing: 1px;">
                    By registering, you agree to our <br />
                    <a href="#" class="login-link">Protocol Terms</a> &amp; <a href="#" class="login-link">Privacy Policy</a>
                </p>
            </div>
        </form>
    </div>
</main>
