@model ManageUserViewModel

@{
    ViewData["Title"] = "Create User";
}

<section class="container px-4 px-md-5 py-5">
    <div class="panel-card">
        <span class="eyebrow">Administrator</span>
        <h1 class="page-title mt-3">Create User Account</h1>

        <form asp-action="CreateUser" method="post" class="row g-4 mt-1">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small col-12"></div>

            <div class="col-md-6">
                <label asp-for="FullName" class="cyber-label"></label>
                <input asp-for="FullName" class="cyber-input" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Email" class="cyber-label"></label>
                <input asp-for="Email" class="cyber-input" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="cyber-label"></label>
                <input asp-for="PhoneNumber" class="cyber-input" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Role" class="cyber-label"></label>
                <select asp-for="Role" class="form-select form-control-dark">
                    <option value="User">User</option>
                    <option value="Admin">Admin</option>
                </select>
            </div>

            <div class="col-12">
                <label asp-for="Address" class="cyber-label"></label>
                <input asp-for="Address" class="cyber-input" />
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Password" class="cyber-label"></label>
                <input asp-for="Password" class="cyber-input" />
                <small class="text-secondary">Minimum 8 characters.</small>
                <span asp-validation-for="Password" class="text-danger small d-block"></span>
            </div>

            <div class="col-12">
                <button class="btn btn-fit-green px-4" type="submit">Create User</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
