@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="container px-4 px-md-5 py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <span class="eyebrow">Administrator</span>
            <h1 class="page-title mt-2" style="font-size: 1.8rem;">Dashboard Overview</h1>
            <p class="text-secondary mb-0">A quick snapshot of FitTrack operations.</p>
        </div>
        
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="panel-card stat-card stat-card-green">
                <span class="stat-label">Total Users</span>
                <strong class="stat-value">@Model.TotalUsers</strong>
            </div>
        </div>
        <div class="col-md-4">
            <div class="panel-card stat-card stat-card-amber">
                <span class="stat-label">Total Transactions</span>
                <strong class="stat-value">@Model.TotalTransactions</strong>
            </div>
        </div>
        <div class="col-md-4">
            <div class="panel-card stat-card stat-card-teal">
                <span class="stat-label">Active Memberships</span>
                <strong class="stat-value">@Model.ActiveMemberships</strong>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12"><h2 class="section-title mb-2">Quick Actions</h2></div>
        <div class="col-6 col-md-3">
            <a asp-action="Users" class="panel-card quick-action d-flex flex-column align-items-center justify-content-center text-center text-decoration-none gap-2 py-4">
                <i class="bi bi-people" style="font-size:1.5rem;color:#96f54c;"></i>
                <span class="small text-white fw-bold">Manage Users</span>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="Transactions" class="panel-card quick-action d-flex flex-column align-items-center justify-content-center text-center text-decoration-none gap-2 py-4">
                <i class="bi bi-receipt" style="font-size:1.5rem;color:#96f54c;"></i>
                <span class="small text-white fw-bold">Transactions</span>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="WalletRequests" class="panel-card quick-action d-flex flex-column align-items-center justify-content-center text-center text-decoration-none gap-2 py-4">
                <i class="bi bi-wallet2" style="font-size:1.5rem;color:#96f54c;"></i>
                <span class="small text-white fw-bold">Wallet Requests</span>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-action="PaymentAccounts" class="panel-card quick-action d-flex flex-column align-items-center justify-content-center text-center text-decoration-none gap-2 py-4">
                <i class="bi bi-bank" style="font-size:1.5rem;color:#96f54c;"></i>
                <span class="small text-white fw-bold">Payment Accounts</span>
            </a>
        </div>
    </div>

    <style>
        /* Quick action hover/focus improvements */
        .quick-action { transition: transform .18s ease, box-shadow .18s ease, background-color .18s ease; cursor: pointer; }
        .quick-action:focus { outline: none; }
        .quick-action:hover, .quick-action:focus {
            transform: translateY(-6px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.25);
            background-color: rgba(150,245,76,0.06); /* subtle green tint */
            text-decoration: none;
        }
        .quick-action:focus { box-shadow: 0 0 0 4px rgba(150,245,76,0.12); }
        .quick-action .bi { transition: transform .18s ease; }
        .quick-action:hover .bi, .quick-action:focus .bi { transform: translateY(-3px); }
    </style>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="panel-card h-100">
                <h2 class="section-title">Newest Members</h2>
                <div class="table-responsive">
                    <table class="table table-dark align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Joined</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.RecentUsers)
                            {
                                <tr>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>@user.JoinedDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="panel-card h-100">
                <h2 class="section-title">Recent Payments</h2>
                <div class="table-responsive">
                    <table class="table table-dark align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Member</th>
                                <th>Plan</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var transaction in Model.RecentTransactions)
                            {
                                <tr>
                                    <td>@transaction.User?.FullName</td>
                                    <td>@transaction.MembershipPlan</td>
                                    <td>
                                        @{
                                            var badgeClass = transaction.Status switch
                                            {
                                                "Approved" => "badge-approved",
                                                "Rejected" => "badge-rejected",
                                                _ => "badge-pending"
                                            };
                                        }
                                        <span class="badge @badgeClass">@transaction.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>