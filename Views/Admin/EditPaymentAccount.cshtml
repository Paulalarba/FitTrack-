@model PaymentAccountViewModel

@{
    ViewData["Title"] = "Edit Payment Account";
}

<section class="container px-4 px-md-5 py-5">
    <div class="panel-card">
        <span class="eyebrow">Payment Details</span>
        <h1 class="page-title mt-3">Edit Payment Account</h1>

        <form asp-action="EditPaymentAccount" method="post" enctype="multipart/form-data" class="row g-4 mt-1">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="ExistingQrCodePath" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger small col-12"></div>

            <partial name="_PaymentAccountForm" model="Model" />

            <div class="col-12 d-flex gap-3">
                <button class="btn btn-fit-green px-4" type="submit">Save Changes</button>
                <a asp-action="PaymentAccounts" class="btn-edit-profile">Cancel</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
