@model List<PaymentAccount>

@{
    ViewData["Title"] = "Payment Accounts";
}

<section class="container px-4 px-md-5 py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <span class="eyebrow">Payment Details</span>
            <h1 class="page-title mt-3">Payment Accounts</h1>
            <p class="text-secondary mb-0">Manage the e-wallet and bank accounts members can use for deposits.</p>
        </div>
        <a asp-action="CreatePaymentAccount" class="btn-fit-green" style="font-size: 0.9rem; padding: 0.5rem 1.2rem;">Add Account</a>
    </div>

    @if (TempData["StatusMessage"] is string message)
    {
        <div class="alert alert-success">@message</div>
    }

    <div class="panel-card">
        <div class="table-responsive">
            <table class="table table-dark align-middle">
                <thead>
                    <tr>
                        <th>QR</th>
                        <th>Type</th>
                        <th>Account Name</th>
                        <th>Account Number</th>
                        <th>Updated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-secondary">No payment accounts yet.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var account in Model)
                        {
                            <tr>
                                <td>
                                    <img src="@account.QrCodePath" alt="@account.PaymentType QR code" class="qr-thumb" />
                                </td>
                                <td><span class="badge-fit rounded-pill px-3 py-2">@account.PaymentType</span></td>
                                <td>@account.AccountName</td>
                                <td>@account.AccountNumber</td>
                                <td>@((account.UpdatedAt ?? account.CreatedAt).ToLocalTime().ToString("MMM dd, yyyy"))</td>
                                <td class="text-end">
                                    <a asp-action="EditPaymentAccount" asp-route-id="@account.Id" class="btn btn-sm btn-outline-light rounded-pill">Edit</a>
                                    <form asp-action="DeletePaymentAccount" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@account.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Remove this payment account?');">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
