@{
    ViewData["Title"] = "Scan QR";
}

<section class="container px-4 px-md-5 py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <span class="eyebrow">Access Control</span>
            <h1 class="page-title mt-2" style="font-size:1.8rem;">QR Scanner</h1>
            <p class="text-secondary mb-0">Verify members before entry and log each check-in.</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline-light rounded-pill px-4">Dashboard</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="panel-card h-100">
                @Html.AntiForgeryToken()

                <ul class="nav nav-pills mb-4 gap-2" id="scanModeTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active px-4" id="tab-qr" data-bs-toggle="pill"
                                data-bs-target="#panel-qr" type="button" role="tab"
                                aria-controls="panel-qr" aria-selected="true">
                            <i class="bi bi-qr-code-scan me-2"></i>QR Scan
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link px-4" id="tab-name" data-bs-toggle="pill"
                                data-bs-target="#panel-name" type="button" role="tab"
                                aria-controls="panel-name" aria-selected="false">
                            <i class="bi bi-person-search me-2"></i>Search by Name
                        </button>
                    </li>
                </ul>

                <div class="tab-content">

                    
                    <div class="tab-pane fade show active" id="panel-qr" role="tabpanel" aria-labelledby="tab-qr">
                        <div id="qrReader" class="qr-reader-shell"></div>
                        <div class="d-flex flex-column flex-sm-row gap-2 mt-3">
                            <button id="startScannerButton" type="button" class="btn btn-fit-green px-4">
                                <i class="bi bi-camera-video me-2"></i>Start Scanner
                            </button>
                            <button id="stopScannerButton" type="button" class="btn btn-outline-light rounded-pill px-4" disabled>
                                <i class="bi bi-stop-circle me-2"></i>Stop
                            </button>
                        </div>
                        <div class="mt-4">
                            <label for="manualQrPayload" class="cyber-label">Manual QR Payload</label>
                            <div class="input-group">
                                <input id="manualQrPayload" type="text" class="form-control form-control-dark" placeholder="Paste scanned payload" />
                                <button id="manualVerifyButton" type="button" class="btn btn-outline-light">Verify</button>
                            </div>
                        </div>
                    </div>

                    
                    <div class="tab-pane fade" id="panel-name" role="tabpanel" aria-labelledby="tab-name">
                        <p class="text-secondary small mb-3">
                            Use this when the QR scanner is unavailable. Search for the member by name
                            or email, then click <strong>Check In</strong> to log their entry.
                        </p>
                        <div class="mb-3">
                            <label for="memberNameSearch" class="cyber-label">Member Name or Email</label>
                            <div class="input-group">
                                <input id="memberNameSearch" type="text" class="form-control form-control-dark"
                                       placeholder="Type at least 2 characters…" autocomplete="off" />
                                <button id="memberSearchButton" type="button" class="btn btn-fit-green">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </div>

                        <div id="searchResultsList" class="mt-2" style="display:none;">
                            <p class="cyber-label mb-2">Results</p>
                            <ul id="memberList" class="list-unstyled member-search-list mb-0"></ul>
                        </div>

                        <div id="searchNoResults" class="text-secondary small mt-2" style="display:none;">
                            No members found. Try a different name or email.
                        </div>

                        <div id="searchSpinner" class="text-secondary small mt-2" style="display:none;">
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span> Searching…
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div id="scanResultPanel" class="panel-card h-100 qr-result-panel">
                <div class="qr-result-empty text-center py-5">
                    <i class="bi bi-qr-code-scan d-block mb-3" style="font-size:3rem;color:#96f54c;"></i>
                    <h2 class="section-title">Ready To Scan</h2>
                    <p class="text-secondary mb-0">Member details will appear here.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    /* ── Nav-pill styling to match existing dark theme ─────────────── */
    #scanModeTabs .nav-link {
        background: rgba(255, 255, 255, 0.06);
        color: var(--text-secondary, #9ca3af);
        border-radius: 50px;
        font-size: .85rem;
        font-weight: 500;
        transition: background .2s, color .2s;
    }

    #scanModeTabs .nav-link:hover {
        background: rgba(150, 245, 76, 0.12);
        color: #96f54c;
    }

    #scanModeTabs .nav-link.active {
        background: #96f54c;
        color: #101311;
    }

    /* ── Member search result list ──────────────────────────────────── */
    .member-search-list .member-card {
        display: flex;
        align-items: center;
        gap: .85rem;
        padding: .75rem 1rem;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        margin-bottom: .5rem;
        transition: background .18s, border-color .18s;
        cursor: default;
    }

    .member-search-list .member-card:last-child {
        margin-bottom: 0;
    }

    .member-card-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
    }

    .member-card-avatar-placeholder {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, #2a3b2a, #1a2a1a);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .72rem;
        font-weight: 700;
        color: #96f54c;
        flex-shrink: 0;
        letter-spacing: .05em;
    }

    .member-card-info {
        flex: 1;
        min-width: 0;
    }

    .member-card-name {
        font-weight: 600;
        font-size: .9rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .member-card-email {
        font-size: .75rem;
        color: var(--text-secondary, #9ca3af);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .member-card-badge {
        font-size: .68rem;
        padding: 2px 8px;
        border-radius: 50px;
        font-weight: 600;
        white-space: nowrap;
    }

    .btn-checkin {
        font-size: .78rem;
        padding: .3rem .9rem;
        border-radius: 50px;
        background: #96f54c;
        color: #101311;
        font-weight: 700;
        border: none;
        flex-shrink: 0;
        transition: opacity .18s, transform .1s;
    }

    .btn-checkin:hover {
        opacity: .88;
        transform: scale(1.03);
    }

    .btn-checkin:disabled {
        opacity: .45;
        cursor: not-allowed;
        transform: none;
    }
</style>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script>
        /* ─── Shared state / DOM refs ────────────────────────────────── */
        const verifyUrl      = '@Url.Action("VerifyQrCode",  "Admin")';
        const manualUrl      = '@Url.Action("ManualCheckIn", "Admin")';
        const lookupUrl      = '@Url.Action("LookupMember",  "Admin")';
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]').value;

        const startButton    = document.getElementById('startScannerButton');
        const stopButton     = document.getElementById('stopScannerButton');
        const manualInput    = document.getElementById('manualQrPayload');
        const manualButton   = document.getElementById('manualVerifyButton');
        const resultPanel    = document.getElementById('scanResultPanel');

        const nameInput      = document.getElementById('memberNameSearch');
        const searchButton   = document.getElementById('memberSearchButton');
        const searchList     = document.getElementById('searchResultsList');
        const memberList     = document.getElementById('memberList');
        const noResults      = document.getElementById('searchNoResults');
        const searchSpinner  = document.getElementById('searchSpinner');

        const qrScanner      = new Html5Qrcode('qrReader');
        let scannerRunning   = false;
        let lastPayload      = '';
        let lastScanAt       = 0;

        /* ─── Helpers ─────────────────────────────────────────────────── */
        function formatDate(value) {
            if (!value) return 'None yet';
            return new Date(value).toLocaleString([], {
                year: 'numeric', month: 'short', day: '2-digit',
                hour: 'numeric', minute: '2-digit'
            });
        }

        function escapeHtml(value) {
            return String(value ?? '').replace(/[&<>"']/g, c => ({
                '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'
            }[c]));
        }

        function playTone(allowed) {
            const ctx = new (window.AudioContext || window.webkitAudioContext)();
            const osc = ctx.createOscillator();
            const gain = ctx.createGain();
            osc.type = 'sine';
            osc.frequency.value = allowed ? 880 : 220;
            gain.gain.value = 0.06;
            osc.connect(gain);
            gain.connect(ctx.destination);
            osc.start();
            osc.stop(ctx.currentTime + 0.14);
        }

        /* ─── Result panel renderer (shared by QR and manual check-in) ─ */
        function renderResult(result) {
            const isAllowed   = result.allowEntry === true;
            const isDuplicate = result.status === 'Duplicate';
            const panelClass  = isAllowed ? 'qr-result-allowed' : 'qr-result-denied';
            const icon        = isAllowed ? 'bi-check-circle' : 'bi-x-circle';
            const badge       = isAllowed ? 'badge-approved'  : 'badge-rejected';
            const title       = isAllowed ? 'Allow Entry' : (isDuplicate ? 'Recently Scanned' : 'Deny Entry');
            const member      = result.member;
            const membership  = result.membership;
            const pic         = escapeHtml(member?.profilePicture);

            resultPanel.className = `panel-card h-100 qr-result-panel ${panelClass}`;
            resultPanel.innerHTML = `
                <div class="d-flex align-items-start gap-3 mb-4">
                    <div class="qr-result-icon"><i class="bi ${icon}"></i></div>
                    <div>
                        <span class="eyebrow">${escapeHtml(result.status)}</span>
                        <h2 class="page-title mt-2 mb-1" style="font-size:1.45rem;">${escapeHtml(title)}</h2>
                        <p class="text-secondary mb-0">${escapeHtml(result.message)}</p>
                    </div>
                </div>

                ${member ? `
                    <div class="d-flex align-items-center gap-3 mb-4">
                        ${pic
                            ? `<img src="${pic}" alt="${escapeHtml(member.fullName)}" class="profile-image" style="width:84px;height:84px;">`
                            : `<div class="profile-image profile-image-placeholder" style="width:84px;height:84px;">FT</div>`}
                        <div>
                            <h3 class="mb-1" style="font-size:1.2rem;">${escapeHtml(member.fullName)}</h3>
                            <p class="text-secondary small mb-0">${escapeHtml(member.email)}</p>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="qr-info-tile">
                                <span class="stat-label">Membership</span>
                                <strong class="stat-value"><span class="badge ${badge}">${escapeHtml(membership?.status ?? 'No membership')}</span></strong>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="qr-info-tile">
                                <span class="stat-label">Plan</span>
                                <strong class="stat-value">${escapeHtml(membership?.planName ?? 'No Plan')}</strong>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="qr-info-tile">
                                <span class="stat-label">Valid Until</span>
                                <strong class="stat-value">${formatDate(membership?.endDate)}</strong>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="qr-info-tile">
                                <span class="stat-label">Last Check-in</span>
                                <strong class="stat-value">${formatDate(result.checkInTime)}</strong>
                            </div>
                        </div>
                    </div>
                ` : `
                    <div class="qr-info-tile">
                        <span class="stat-label">Result</span>
                        <strong class="stat-value">${escapeHtml(result.message)}</strong>
                    </div>
                `}
            `;
        }

        /* ─── QR scan flow ────────────────────────────────────────────── */
        async function verifyPayload(payload) {
            const trimmedPayload = payload?.trim();
            if (!trimmedPayload) return;

            const now = Date.now();
            if (trimmedPayload === lastPayload && now - lastScanAt < 2500) return;
            lastPayload = trimmedPayload;
            lastScanAt  = now;

            const response = await fetch(verifyUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': antiForgeryToken
                },
                body: JSON.stringify({ qrPayload: trimmedPayload })
            });

            if (!response.ok) throw new Error('Verification request failed.');

            const result = await response.json();
            renderResult(result);
            playTone(result.allowEntry === true);
        }

        async function startScanner() {
            if (scannerRunning) return;
            await qrScanner.start(
                { facingMode: 'environment' },
                { fps: 10, qrbox: { width: 260, height: 260 } },
                verifyPayload
            );
            scannerRunning = true;
            startButton.disabled = true;
            stopButton.disabled  = false;
        }

        async function stopScanner() {
            if (!scannerRunning) return;
            await qrScanner.stop();
            scannerRunning = false;
            startButton.disabled = false;
            stopButton.disabled  = true;
        }

        startButton.addEventListener('click', () => {
            startScanner().catch(err => {
                resultPanel.innerHTML = `<div class="alert alert-danger mb-0">${err.message}</div>`;
            });
        });

        stopButton.addEventListener('click', () => stopScanner().catch(() => {}));

        manualButton.addEventListener('click', () => {
            verifyPayload(manualInput.value).catch(err => {
                resultPanel.innerHTML = `<div class="alert alert-danger mb-0">${err.message}</div>`;
            });
        });

        /* ─── Name-search flow ────────────────────────────────────────── */
        function memberStatusBadge(membership) {
            if (!membership) return '<span class="member-card-badge" style="background:rgba(255,255,255,.1);color:#9ca3af;">No Plan</span>';
            const isActive = membership.status === 'Active';
            return `<span class="member-card-badge" style="background:${isActive ? 'rgba(150,245,76,.18);color:#96f54c' : 'rgba(239,68,68,.18);color:#f87171'}">${escapeHtml(membership.status)}</span>`;
        }

        function buildMemberCard(member) {
            const pic = escapeHtml(member.profilePicture);
            const avatar = pic
                ? `<img src="${pic}" alt="${escapeHtml(member.fullName)}" class="member-card-avatar">`
                : `<div class="member-card-avatar-placeholder">FT</div>`;

            const li = document.createElement('li');
            li.innerHTML = `
                <div class="member-card">
                    ${avatar}
                    <div class="member-card-info">
                        <div class="member-card-name">${escapeHtml(member.fullName)}</div>
                        <div class="member-card-email">${escapeHtml(member.email ?? '')}</div>
                    </div>
                    ${memberStatusBadge(member.membership)}
                    <button type="button" class="btn-checkin" data-member-id="${escapeHtml(member.id)}" data-member-name="${escapeHtml(member.fullName)}">
                        Check&nbsp;In
                    </button>
                </div>
            `;

            /* Attach check-in handler to this card's button */
            const btn = li.querySelector('.btn-checkin');
            btn.addEventListener('click', () => performManualCheckIn(btn));
            return li;
        }

        async function searchMembers() {
            const query = nameInput.value.trim();
            if (query.length < 2) {
                searchList.style.display  = 'none';
                noResults.style.display   = 'none';
                return;
            }

            searchSpinner.style.display = 'block';
            searchList.style.display    = 'none';
            noResults.style.display     = 'none';
            memberList.innerHTML        = '';

            try {
                const url = `${lookupUrl}?name=${encodeURIComponent(query)}`;
                const res = await fetch(url, { headers: { 'RequestVerificationToken': antiForgeryToken } });
                if (!res.ok) throw new Error('Search failed.');

                const data = await res.json();
                searchSpinner.style.display = 'none';

                if (!data.results || data.results.length === 0) {
                    noResults.style.display = 'block';
                    return;
                }

                data.results.forEach(m => memberList.appendChild(buildMemberCard(m)));
                searchList.style.display = 'block';
            } catch (err) {
                searchSpinner.style.display = 'none';
                noResults.textContent       = 'Search error: ' + err.message;
                noResults.style.display     = 'block';
            }
        }

        async function performManualCheckIn(btn) {
            const memberId   = btn.dataset.memberId;
            const memberName = btn.dataset.memberName;
            btn.disabled     = true;
            btn.textContent  = '…';

            try {
                const res = await fetch(manualUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': antiForgeryToken
                    },
                    body: JSON.stringify({ memberId })
                });

                if (!res.ok) throw new Error('Check-in request failed.');

                const result = await res.json();
                renderResult(result);
                playTone(result.allowEntry === true);
            } catch (err) {
                resultPanel.innerHTML = `<div class="alert alert-danger mb-0">Check-in failed: ${err.message}</div>`;
            } finally {
                btn.disabled    = false;
                btn.textContent = 'Check In';
            }
        }

        /* Search on button click */
        searchButton.addEventListener('click', () => searchMembers());

        /* Search on Enter key */
        nameInput.addEventListener('keydown', e => {
            if (e.key === 'Enter') searchMembers();
        });

        /* Debounced live search as the admin types */
        let debounceTimer = null;
        nameInput.addEventListener('input', () => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(searchMembers, 380);
        });

        /* Stop QR scanner when switching away from the QR tab */
        document.getElementById('tab-name').addEventListener('shown.bs.tab', () => {
            stopScanner().catch(() => {});
        });

        window.addEventListener('beforeunload', () => {
            if (scannerRunning) qrScanner.stop().catch(() => {});
        });
    </script>
}
