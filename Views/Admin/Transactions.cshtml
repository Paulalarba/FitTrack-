@model AdminTransactionsViewModel

@{
    ViewData["Title"] = "Transactions";
}

<section class="container px-4 px-md-5 py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <span class="eyebrow">Payments</span>
            <h1 class="page-title mt-3">Transactions</h1>
            <p class="text-secondary mb-0">Search and approve membership payment requests.</p>
        </div>
    </div>

    @if (TempData["StatusMessage"] is string message)
    {
        <div class="alert alert-success">@message</div>
    }

    <div class="panel-card">
        <form method="get" class="row g-3 align-items-end mb-4">
            <div class="col-md-6">
                <label class="cyber-label">Search</label>
                <input type="text" name="searchTerm" value="@Model.SearchTerm" class="cyber-input" placeholder="Search by member, plan, or transaction ID" />
            </div>
            <div class="col-md-3">
                <label class="cyber-label">Status</label>
                <select name="statusFilter" class="form-select form-control-dark">
                    <option value="">All</option>
                    <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                    <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                    <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
                </select>
            </div>
            <div class="col-md-3">
                <button class="btn btn-fit-green w-100" type="submit">Filter</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-dark align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Member</th>
                        <th>Plan</th>
                        <th>Amount</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var transaction in Model.Transactions)
                    {
                        <tr>
                            <td>#@transaction.Id</td>
                            <td>@transaction.User?.FullName</td>
                            <td>@transaction.MembershipPlan</td>
                            <td>@transaction.Amount.ToString("C")</td>
                            <td>@transaction.PaymentDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                            <td><span class="badge badge-fit">@transaction.Status</span></td>
                            <td class="text-end">
                                @if (transaction.Status == "Pending")
                                {
                                    <form asp-action="UpdateTransactionStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@transaction.Id" />
                                        <input type="hidden" name="status" value="Approved" />
                                        <button class="btn btn-sm btn-outline-success rounded-pill" type="submit">Approve</button>
                                    </form>
                                    <form asp-action="UpdateTransactionStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@transaction.Id" />
                                        <input type="hidden" name="status" value="Rejected" />
                                        <button class="btn btn-sm btn-outline-danger rounded-pill" type="submit">Reject</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-fit mt-4">
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-action="Transactions" asp-route-searchTerm="@Model.SearchTerm" asp-route-statusFilter="@Model.StatusFilter" asp-route-page="@i" class="@(Model.Page == i ? "active" : string.Empty)">@i</a>
            }
        </div>
    </div>
</section>
