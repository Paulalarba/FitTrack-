@model AdminUsersViewModel

@{
    ViewData["Title"] = "Manage Users";
}

<section class="container px-4 px-md-5 py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <span class="eyebrow">Account Management</span>
            <h1 class="page-title mt-3">Users</h1>
            <p class="text-secondary mb-0">Search, review, edit, and delete member accounts.</p>
        </div>
        <a asp-action="CreateUser" class="btn-edit-profile" style="font-size: 0.9rem; padding: 0.5rem 1.2rem;">Create User</a>
    </div>

    @if (TempData["StatusMessage"] is string message)
    {
        <div class="alert alert-success">@message</div>
    }

    <div class="panel-card">
        <form method="get" class="row g-3 align-items-end mb-4">
            <div class="col-md-8">
                <label class="cyber-label">Search Users</label>
                <input type="text" name="searchTerm" value="@Model.SearchTerm" class="cyber-input" placeholder="Search by name, email, or ID" />
            </div>
            <div class="col-md-4">
                <button class="btn btn-fit-green w-100" type="submit" style="font-size: 0.9rem; padding: 0.5rem 1.2rem;">Search</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-dark align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Membership</th>
                        <th>Joined</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge-role-admin">Admin</span>
                                }
                                else
                                {
                                    <span class="badge-role-member">Member</span>
                                }
                            </td>
                            <td>@user.MembershipStatus</td>
                            <td>@user.JoinedDate.ToLocalTime().ToString("MMM dd, yyyy")</td>
                            <td class="text-end">
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-light rounded-pill">Edit</a>
                                <form asp-action="DeleteUser" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Delete this user account?');">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-fit mt-4">
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <a asp-action="Users" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@i" class="@(Model.Page == i ? "active" : string.Empty)">@i</a>
            }
        </div>
    </div>
</section>
