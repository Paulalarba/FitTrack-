@model List<WalletTransaction>

@{
    ViewData["Title"] = "Wallet Requests";
}

<section class="container px-4 px-md-5 py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <span class="eyebrow">Wallet Funding</span>
            <h1 class="page-title mt-3">Wallet Requests</h1>
            <p class="text-secondary mb-0">Review pending member deposit requests before funds are credited.</p>
        </div>
    </div>

    @if (TempData["StatusMessage"] is string message)
    {
        <div class="alert alert-success">@message</div>
    }

    <div class="panel-card">
        <div class="table-responsive">
            <table class="table table-dark align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Member</th>
                        <th>Amount</th>
                        <th>Method</th>
                        <th>Reference</th>
                        <th>Proof</th>
                        <th>Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-secondary">No pending wallet deposit requests.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var request in Model)
                        {
                            <tr>
                                <td>#@request.Id</td>
                                <td>@request.Wallet?.User?.FullName</td>
                                <td>@request.Amount.ToString("C")</td>
                                <td>@request.PaymentMethod</td>
                                <td>@(string.IsNullOrWhiteSpace(request.ReferenceNumber) ? "-" : request.ReferenceNumber)</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(request.ProofPath))
                                    {
                                        <a href="@request.ProofPath" target="_blank" rel="noopener" class="text-fit-green">View proof</a>
                                    }
                                    else
                                    {
                                        <span class="text-secondary">-</span>
                                    }
                                </td>
                                <td>@request.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td class="text-end">
                                    <form asp-action="ApproveDeposit" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@request.Id" />
                                        <button class="btn btn-sm btn-outline-success rounded-pill" type="submit">Approve</button>
                                    </form>
                                    <form asp-action="RejectDeposit" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@request.Id" />
                                        <button class="btn btn-sm btn-outline-danger rounded-pill" type="submit">Reject</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
