@model PaymentAccountViewModel

<div class="col-md-6">
    <label asp-for="PaymentType" class="cyber-label"></label>
    <select asp-for="PaymentType" class="form-select form-control-dark">
        <option value="GCash">GCash</option>
        <option value="Bank Account">Bank Account</option>
        <option value="Maya">Maya</option>
        <option value="PayMaya">PayMaya</option>
        <option value="Other E-wallet">Other E-wallet</option>
    </select>
    <span asp-validation-for="PaymentType" class="text-danger small"></span>
</div>

<div class="col-md-6">
    <label asp-for="AccountName" class="cyber-label"></label>
    <input asp-for="AccountName" class="cyber-input" />
    <span asp-validation-for="AccountName" class="text-danger small"></span>
</div>

<div class="col-md-6">
    <label asp-for="AccountNumber" class="cyber-label"></label>
    <input asp-for="AccountNumber" class="cyber-input" />
    <span asp-validation-for="AccountNumber" class="text-danger small"></span>
</div>

<div class="col-md-6">
    <label asp-for="QrCodeFile" class="cyber-label"></label>
    <input asp-for="QrCodeFile" class="form-control form-control-dark" type="file" accept=".jpg,.jpeg,.png,.webp" />
    <span asp-validation-for="QrCodeFile" class="text-danger small"></span>
    @if (!string.IsNullOrWhiteSpace(Model.ExistingQrCodePath))
    {
        <div class="mt-3">
            <img src="@Model.ExistingQrCodePath" alt="Current QR code" class="qr-thumb" />
            <small class="text-secondary d-block mt-2">Upload a new image to replace the current QR code.</small>
        </div>
    }
</div>
