@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5 text-white">
    <div class="row justify-content-center">
        <div class="col-lg-8 text-center">

            <h1 class="fw-bold fst-italic mb-2">
                About <span class="text-fit-green">FITTRACK</span>
            </h1>
            <p class="text-secondary text-uppercase tracking-widest small mb-5">Gym Management Made Simple.</p>

            <p class="lead mb-4">
                FitTrack is a web-based gym management system designed to simplify the day-to-day
                operations of a fitness center. Built for both administrators and members, it provides
                a centralized platform for managing memberships, tracking payments, and monitoring
                member activity.
            </p>

           

            <hr class="border-secondary my-5" />

            <h4 class="fw-bold mb-4">What FitTrack Offers</h4>
            <div class="row g-4 text-start">
                <div class="col-md-6">
                    <div class="p-4 rounded-3 h-100" style="background-color: #1a1a1a;">
                        <h6 class="text-fit-green fw-bold mb-2">For Administrators</h6>
                        <p class="text-secondary small mb-0">Manage gym members, approve or reject payment requests, and monitor overall membership status from a centralized dashboard.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-4 rounded-3 h-100" style="background-color: #1a1a1a;">
                        <h6 class="text-fit-green fw-bold mb-2">For Members</h6>
                        <p class="text-secondary small mb-0">View membership status, submit payment requests, and track billing history through a simple self-service dashboard.</p>
                    </div>
                </div>
            </div>

            <div class="mt-5">
                <a asp-controller="Account" asp-action="Login" class="btn btn-fit-green px-4 py-2 me-2">Get Started</a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 py-2">Back to Home</a>
            </div>

        </div>
    </div>
</div>