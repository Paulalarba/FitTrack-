@{
    ViewData["Title"] = "Contact";
}

<div class="container py-5 text-white">
    <div class="row justify-content-center">
        <div class="col-lg-8 text-center">

            <h1 class="fw-bold fst-italic mb-2">
                Contact <span class="text-fit-green">US</span>
            </h1>
            <p class="text-secondary text-uppercase tracking-widest small mb-5">We'd love to hear from you.</p>

            <div class="row g-4 text-start mb-5">
                <div class="col-md-4">
                    <div class="p-4 rounded-3 h-100 text-center" style="background-color: #1a1a1a;">
                        <i class="bi bi-envelope mb-3 d-block" style="color: #96f54c; font-size: 1.5rem;"></i>
                        <h6 class="text-fit-green fw-bold mb-2">Email</h6>
                        <p class="text-secondary small mb-0">aaltheakathleen@gmail.com</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4 rounded-3 h-100 text-center" style="background-color: #1a1a1a;">
                        <i class="bi bi-telephone mb-3 d-block" style="color: #96f54c; font-size: 1.5rem;"></i>
                        <h6 class="text-fit-green fw-bold mb-2">Phone</h6>
                        <p class="text-secondary small mb-0">+63 912 345 6789</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-4 rounded-3 h-100 text-center" style="background-color: #1a1a1a;">
                        <i class="bi bi-geo-alt mb-3 d-block" style="color: #96f54c; font-size: 1.5rem;"></i>
                        <h6 class="text-fit-green fw-bold mb-2">Location</h6>
                        <p class="text-secondary small mb-0">Cebu City, Philippines</p>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 py-2">Back to Home</a>
            </div>

        </div>
    </div>
</div>