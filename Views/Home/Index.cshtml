@{
    ViewData["Title"] = "Home Page";
}

<main class="container px-4 px-md-5 position-relative z-1">
    <section class="row align-items-center mt-2 pt-5 pt-lg-4 overflow-hidden">
        <!-- Left Column: Hero Text -->
        <div class="col-lg-6 d-flex flex-column align-items-center align-items-lg-start text-center text-lg-start gap-4" style="z-index: 10; position: relative;">
            <h1 class="hero-title-landing fw-bold fst-italic text-uppercase tracking-wide">
                <span class="neon-text d-block">GET FIT</span>
                <span class="neon-text d-block">WITH</span>
                <span class="text-white d-block">FITTRACK</span>
            </h1>
            
            <p class="fs-5 text-light opacity-75 mx-auto mx-lg-0" style="max-width: 500px;">
                A complete SaaS platform connecting gym owners, trainers, and clients — powered by AI for smarter coaching, personalized nutrition, and real-time progress tracking.
            </p>

            <div class="w-100 d-flex justify-content-center justify-content-lg-start">
                <a asp-controller="Booking" asp-action="Index" class="btn btn-fit-green btn-lg px-5 py-3">
                    Pre-Book Now
                </a>
            </div>
        </div>
    
        <!-- Right Column: Dashboard Mockup -->
        <div class="col-lg-6 d-flex justify-content-center justify-content-lg-end mt-5 mt-lg-0 order-last order-lg-2">
            <div class="position-relative w-100 glow-border p-2 bg-dark rounded-4 shadow-strong" style="max-width: 700px;">
                <img src="~/Public/FitTrackAdmin.png"
                     class="img-fluid rounded-3 opacity-75"
                     alt="FitTrack Dashboard Mockup" />
            </div>
        </div>
    </section>
</main>
