@{
    ViewData["Title"] = "FitTrack";
}

<main class="container px-4 px-md-5 position-relative z-1">
    <section class="row align-items-center mt-2 pt-5 pt-lg-4 g-5">
        <div class="col-lg-6 d-flex flex-column align-items-center align-items-lg-start text-center text-lg-start gap-4">
            <span class="eyebrow">Gym Management System</span>
            <h1 class="hero-title-landing fw-bold fst-italic text-uppercase tracking-wide">
                <span class="neon-text d-block">Run Your Gym</span>
                <span class="text-white d-block">With Clarity</span>
            </h1>

            <p class="fs-5 text-light opacity-75 mx-auto mx-lg-0 hero-copy">
                FitTrack gives administrators a control center for members, memberships, and payments while members get a simple self-service dashboard for profiles and billing history.
            </p>

            <div class="d-flex flex-column flex-sm-row gap-3">
                <a asp-controller="Account" asp-action="SignUp" class="btn btn-fit-green btn-lg px-5 py-3">Create Member Account</a>
               
            </div>
        </div>

        <div class="col-lg-6">
            <div class="position-relative glow-border p-3 bg-dark rounded-4 shadow-strong">
                <img src="~/Public/FitTrackAdmin.png" class="img-fluid rounded-4 opacity-75" alt="FitTrack dashboard preview" />
            </div>
        </div>
    </section>

    <section class="row g-4 mt-5 pt-4">
        <div class="col-md-4">
            <div class="panel-card h-100">
                <h3 class="panel-title">Admin Controls</h3>
                <p class="text-secondary mb-0">Manage users, approve transactions, search records, and monitor active memberships from one dashboard.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="panel-card h-100">
                <h3 class="panel-title">Member Self-Service</h3>
                <p class="text-secondary mb-0">Members can register, edit profiles, upload a profile photo, view membership status, and track recent payment activity.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="panel-card h-100">
                <h3 class="panel-title">Built for Growth</h3>
                <p class="text-secondary mb-0">Validation, pagination, and SQL-backed persistence create a strong base for payment gateways, notifications, and future mobile support.</p>
            </div>
        </div>
    </section>


    <section class="py-5 mt-4">
        <div class="text-center mb-5">
            <span class="eyebrow">Simple Process</span>
            <h2 class="fw-bold fst-italic text-white mt-2" style="font-size:2rem;">HOW IT WORKS</h2>
        </div>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="panel-card h-100 d-flex flex-column align-items-center py-4">
                    <div style="width:56px;height:56px;border-radius:50%;background:rgba(150,245,76,0.15);border:2px solid #96f54c;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;color:#96f54c;margin-bottom:1rem;">1</div>
                    <i class="bi bi-person-plus mb-3" style="font-size:1.8rem;color:#96f54c;"></i>
                    <h5 class="text-white fw-bold mb-2">Sign Up</h5>
                    <p class="text-secondary small mb-0">Create your member account in seconds and get instant access to your personal dashboard.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="panel-card h-100 d-flex flex-column align-items-center py-4">
                    <div style="width:56px;height:56px;border-radius:50%;background:rgba(150,245,76,0.15);border:2px solid #96f54c;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;color:#96f54c;margin-bottom:1rem;">2</div>
                    <i class="bi bi-card-checklist mb-3" style="font-size:1.8rem;color:#96f54c;"></i>
                    <h5 class="text-white fw-bold mb-2">Choose a Plan</h5>
                    <p class="text-secondary small mb-0">Browse available membership plans and submit a payment request to get started.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="panel-card h-100 d-flex flex-column align-items-center py-4">
                    <div style="width:56px;height:56px;border-radius:50%;background:rgba(150,245,76,0.15);border:2px solid #96f54c;display:flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:700;color:#96f54c;margin-bottom:1rem;">3</div>
                    <i class="bi bi-graph-up mb-3" style="font-size:1.8rem;color:#96f54c;"></i>
                    <h5 class="text-white fw-bold mb-2">Track Your Membership</h5>
                    <p class="text-secondary small mb-0">Monitor your membership status, wallet balance, and payment history all in one place.</p>
                </div>
            </div>
        </div>
    </section>

   
    
</main>
