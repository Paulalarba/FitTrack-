@model List<PaymentAccount>

@{
    ViewData["Title"] = "Payment Options";
}

<section class="container px-4 px-md-5 py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <span class="eyebrow">Admin Payment Details</span>
            <h1 class="page-title mt-3">Payment Options</h1>
            <p class="text-secondary mb-0">Use one of these official accounts when funding your wallet.</p>
        </div>
        <a asp-controller="Wallet" asp-action="Deposit" class="btn btn-fit-green">Deposit Funds</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="panel-card">
            <p class="text-secondary mb-0">No payment accounts are available yet.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var account in Model)
            {
                var modalId = $"qrModal{account.Id}";
                <div class="col-md-6 col-xl-4">
                    <article class="payment-option-card h-100">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="payment-icon">
                                <span class="material-symbols-outlined">@GetPaymentIcon(account.PaymentType)</span>
                            </div>
                            <div>
                                <span class="stat-label">@account.PaymentType</span>
                                <h2 class="section-title mb-0">@account.AccountName</h2>
                            </div>
                        </div>

                        <button type="button" class="qr-preview-button" data-bs-toggle="modal" data-bs-target="#@modalId">
                            <img src="@account.QrCodePath" alt="@account.PaymentType QR code" class="payment-qr" />
                        </button>

                        <dl class="payment-details mt-3 mb-0">
                            <dt>Account Number</dt>
                            <dd class="d-flex align-items-center justify-content-between gap-2">
                                <span id="accountNumber@(account.Id)">@account.AccountNumber</span>
                                <button type="button" class="btn btn-sm btn-outline-light rounded-pill copy-account-btn" data-account-number="@account.AccountNumber">Copy</button>
                            </dd>
                        </dl>
                    </article>
                </div>

                <div class="modal fade" id="@modalId" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content bg-dark border border-success-subtle">
                            <div class="modal-header border-secondary">
                                <h2 class="modal-title fs-5">@account.PaymentType QR Code</h2>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body text-center">
                                <img src="@account.QrCodePath" alt="@account.PaymentType QR code enlarged" class="qr-modal-image" />
                                <p class="text-secondary mt-3 mb-0">@account.AccountName - @account.AccountNumber</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

@functions {
    private static string GetPaymentIcon(string paymentType)
    {
        return paymentType switch
        {
            "Bank Account" => "account_balance",
            "GCash" => "phone_iphone",
            "Maya" => "account_balance_wallet",
            "PayMaya" => "account_balance_wallet",
            _ => "payments"
        };
    }
}

@section Scripts {
    <script>
        document.querySelectorAll('.copy-account-btn').forEach((button) => {
            button.addEventListener('click', async () => {
                const accountNumber = button.dataset.accountNumber;
                await navigator.clipboard.writeText(accountNumber);
                const originalText = button.textContent;
                button.textContent = 'Copied';
                setTimeout(() => button.textContent = originalText, 1400);
            });
        });
    </script>
}
