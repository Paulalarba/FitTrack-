@model TransferFundsViewModel

@{
    ViewData["Title"] = "Transfer Funds";
}

<section class="container px-4 px-md-5 py-5">
    <div class="panel-card">
        <span class="eyebrow">Wallet Transfer</span>
        <h1 class="page-title mt-3">Transfer Funds</h1>
        <p class="text-secondary">Send approved wallet funds to another member using their registered phone number.</p>

        <div class="alert alert-dark border border-success-subtle text-white">
            Available balance: <strong class="text-fit-green">@Model.WalletBalance.ToString("C")</strong>
        </div>

        <form asp-action="TransferFunds" method="post" class="row g-4 mt-1" id="transferFundsForm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small col-12"></div>

            <div class="col-md-6">
                <label asp-for="RecipientPhoneNumber" class="cyber-label"></label>
                <input asp-for="RecipientPhoneNumber" class="cyber-input" id="recipientPhoneInput" autocomplete="off" />
                <span asp-validation-for="RecipientPhoneNumber" class="text-danger small"></span>
                <small class="d-block mt-2" id="recipientPreview"></small>
            </div>

            <div class="col-md-6">
                <label asp-for="Amount" class="cyber-label"></label>
                <input asp-for="Amount" class="cyber-input" min="1" max="100000" step="0.01" />
                <span asp-validation-for="Amount" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Note" class="cyber-label"></label>
                <textarea asp-for="Note" class="form-control form-control-dark" rows="3" placeholder="Optional transfer message"></textarea>
                <span asp-validation-for="Note" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex gap-3">
                <button class="btn btn-fit-green px-4" type="submit" id="transferSubmitButton">Send Transfer</button>
                <a asp-controller="Wallet" asp-action="Index" class="btn-edit-profile">Back to Wallet</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const phoneInput = document.getElementById('recipientPhoneInput');
        const preview = document.getElementById('recipientPreview');
        const form = document.getElementById('transferFundsForm');
        const submitButton = document.getElementById('transferSubmitButton');
        let lookupTimer;

        phoneInput.addEventListener('input', () => {
            clearTimeout(lookupTimer);
            preview.textContent = '';
            preview.className = 'd-block mt-2';

            const phoneNumber = phoneInput.value.trim();
            if (phoneNumber.length < 5) {
                return;
            }

            lookupTimer = setTimeout(async () => {
                const response = await fetch(`/Member/LookupRecipient?phoneNumber=${encodeURIComponent(phoneNumber)}`);
                if (!response.ok) {
                    return;
                }

                const result = await response.json();
                if (!result.found) {
                    preview.textContent = 'No member found with this phone number.';
                    preview.classList.add('text-danger');
                    return;
                }

                if (result.isSelf) {
                    preview.textContent = 'This is your own phone number.';
                    preview.classList.add('text-danger');
                    return;
                }

                preview.textContent = `Recipient: ${result.fullName}`;
                preview.classList.add('text-fit-green');
            }, 350);
        });

        form.addEventListener('submit', () => {
            submitButton.disabled = true;
            submitButton.textContent = 'Sending...';
        });
    </script>
}
