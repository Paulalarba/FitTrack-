<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitTrack</title>
    <link rel="icon" type="image/png" href="~/Public/fittrack_logo.png?v=2" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/Site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <div class="bg-grid-pattern"></div>

    <partial name="_Navbar" />

    <main role="main" class="pb-5">
        @RenderBody()
    </main>

    <div class="flare flare-1"></div>
    <div class="flare flare-2"></div>

    @if (User.Identity?.IsAuthenticated != true)
    {
        <footer style="background-color: #0e110f; border-top: 1px solid rgba(150, 245, 76, 0.15); padding: 3rem 0 1.5rem;">
            <div class="container">
                <div class="row gy-4">

                    <div class="col-lg-3 col-md-6">
                        <div class="fw-bold fst-italic text-white mb-1" style="font-size: 1.4rem; letter-spacing: 0.05em;">FITTRACK</div>
                        <p class="text-secondary small">Gym Management Made Simple.</p>
                        <div class="d-flex gap-3 mt-3">
                            <a href="https://web.facebook.com/paul.alarba.56" target="_blank" style="color: #96f54c; font-size: 1.3rem;"><i class="bi bi-facebook"></i></a>
                            <a href="https://www.instagram.com/paul_lllll?igsh=b2xwb2Ntam44ZWFk" target="_blank" style="color: #96f54c; font-size: 1.3rem;"><i class="bi bi-instagram"></i></a>
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <p class="text-uppercase text-secondary small fw-bold mb-3" style="letter-spacing: 0.15em;">Quick Links</p>
                        <ul class="list-unstyled d-flex flex-column gap-2">
                            <li><a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none small">Home</a></li>
                            <li><a asp-controller="Home" asp-action="AboutUs" class="text-white text-decoration-none small">About Us</a></li>
                            <li><a asp-controller="Home" asp-action="Contact" class="text-white text-decoration-none small">Contact</a></li>
                            <li><a asp-controller="Account" asp-action="Login" class="text-white text-decoration-none small">Login</a></li>
                            <li><a asp-controller="Account" asp-action="SignUp" class="text-white text-decoration-none small">Join Now</a></li>
                        </ul>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <p class="text-uppercase text-secondary small fw-bold mb-3" style="letter-spacing: 0.15em;">Contact Us</p>
                        <ul class="list-unstyled d-flex flex-column gap-2">
                            <li class="small text-white"><i class="bi bi-envelope me-2" style="color: #96f54c;"></i>support@fittrack.com</li>
                            <li class="small text-white"><i class="bi bi-telephone me-2" style="color: #96f54c;"></i>09276077381</li>
                            <li class="small text-white"><i class="bi bi-geo-alt me-2" style="color: #96f54c;"></i>Cebu City, Philippines</li>
                        </ul>
                    </div>

                    <div class="col-lg-3 col-md-6">
                        <p class="text-uppercase text-secondary small fw-bold mb-3" style="letter-spacing: 0.15em;">Opening Hours</p>
                        <ul class="list-unstyled d-flex flex-column gap-2">
                            <li class="small text-white d-flex justify-content-between"><span>Mon - Fri</span><span style="color: #96f54c;">5:00 AM - 10:00 PM</span></li>
                            <li class="small text-white d-flex justify-content-between"><span>Saturday</span><span style="color: #96f54c;">6:00 AM - 8:00 PM</span></li>
                            <li class="small text-white d-flex justify-content-between"><span>Sunday</span><span style="color: #96f54c;">7:00 AM - 6:00 PM</span></li>
                        </ul>
                    </div>

                </div>

                <hr style="border-color: rgba(150, 245, 76, 0.1); margin-top: 2.5rem;" />
                <p class="text-secondary text-center small mb-0">Copyright &copy; 2026 FitTrack. All rights reserved.</p>
            </div>
        </footer>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
