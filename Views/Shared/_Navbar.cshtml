@using System.Security.Claims

@{
    var role = User.FindFirstValue(ClaimTypes.Role);
}

<nav class="navbar navbar-expand-lg navbar-dark bg-transparent py-3 px-4 px-md-5 position-relative z-1">
    <div class="container-fluid p-0">
        <a class="navbar-brand d-flex flex-column" asp-controller="Home" asp-action="Index">
            <div class="font-display fw-bold fst-italic h4 mb-0 d-flex align-items-center gap-2 tracking-wider">
                <img src="~/Public/fittrack_logo.png" alt="FitTrack Logo" style="height: 36px; width: 36px; object-fit: contain; border-radius: 8px;" />
                <span class="text-fit-green">FITTRACK</span>
            </div>
            <span class="text-uppercase tracking-widest text-secondary small nav-subtitle">
                Gym management made simple.
            </span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <div class="navbar-nav ms-auto gap-2 align-items-lg-center">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    if (role == "Admin")
                    {
                        <a asp-controller="Admin" asp-action="Dashboard" class="nav-link nav-link-custom px-3">Dashboard</a>
                        <a asp-controller="Admin" asp-action="ScanQR" class="nav-link nav-link-custom px-3">Scan QR</a>
                        <a asp-controller="Admin" asp-action="Users" class="nav-link nav-link-custom px-3">Users</a>
                        <div class="nav-item dropdown">
                            <a class="nav-link nav-link-custom px-3 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Payments
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark" style="background-color:#1a1a1a; border:1px solid rgba(150,245,76,0.2);">
                                <li><a asp-controller="Admin" asp-action="Transactions" class="dropdown-item text-white">Transactions</a></li>
                                <li><a asp-controller="Admin" asp-action="WalletRequests" class="dropdown-item text-white">Wallet Requests</a></li>
                                <li><a asp-controller="Admin" asp-action="PaymentAccounts" class="dropdown-item text-white">Payment Accounts</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Member" asp-action="Dashboard" class="nav-link nav-link-custom px-3">Dashboard</a>
                        <a asp-controller="Member" asp-action="QR" class="nav-link nav-link-custom px-3">My QR</a>
                        <div class="nav-item dropdown">
                            <a class="nav-link nav-link-custom px-3 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                Payments
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark" style="background-color:#1a1a1a; border:1px solid rgba(150,245,76,0.2);">
                                <li><a asp-controller="Wallet" asp-action="Index" class="dropdown-item text-white">Wallet</a></li>
                                <li><a asp-controller="Member" asp-action="TransferFunds" class="dropdown-item text-white">Transfer</a></li>
                                <li><a asp-controller="Member" asp-action="PaymentOptions" class="dropdown-item text-white">Payment Options</a></li>
                                <li><a asp-controller="Member" asp-action="Transactions" class="dropdown-item text-white">My Payments</a></li>
                            </ul>
                        </div>
                    }

                    <a asp-controller="Account" asp-action="Profile" class="nav-link nav-link-custom px-3">Profile</a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="ms-lg-2">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-fit-green px-4 py-2 mt-3 mt-lg-0" type="submit">Log Out</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Home" asp-action="Index" class="nav-link nav-link-custom px-3">Home</a>
                    <a asp-controller="Home" asp-action="AboutUs" class="nav-link nav-link-custom px-3">About Us</a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-fit-green px-4 py-2 mt-3 mt-lg-0">Login</a>
                }
            </div>
        </div>
    </div>
</nav>
