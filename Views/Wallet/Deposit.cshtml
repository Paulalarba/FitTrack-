@model DepositFundsViewModel

@{
    ViewData["Title"] = "Deposit Funds";
}

<section class="container px-4 px-md-5 py-5">
    <div class="panel-card">
        <span class="eyebrow">Member Wallet</span>
        <h1 class="page-title mt-3">Deposit Funds</h1>
        <p class="text-secondary">Deposit requests are reviewed by an administrator before funds are added to your wallet.</p>
        <a asp-controller="Member" asp-action="PaymentOptions" class="text-fit-green d-inline-block mb-3">View admin payment accounts and QR codes</a>

        <form asp-action="Deposit" method="post" enctype="multipart/form-data" class="row g-4 mt-1">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small col-12"></div>

            <div class="col-md-6">
                <label asp-for="Amount" class="cyber-label"></label>
                <input asp-for="Amount" class="cyber-input" min="1" step="0.01" />
                <span asp-validation-for="Amount" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="PaymentMethod" class="cyber-label"></label>
                <select asp-for="PaymentMethod" class="form-select form-control-dark" id="paymentMethodSelect">
                    <option value="Online">Online</option>
                    <option value="In-person">In-person</option>
                </select>
                <span asp-validation-for="PaymentMethod" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ReferenceNumber" class="cyber-label"></label>
                <input asp-for="ReferenceNumber" class="cyber-input" placeholder="Required for online deposits" />
                <span asp-validation-for="ReferenceNumber" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ProofFile" class="cyber-label"></label>
                <input asp-for="ProofFile" class="form-control form-control-dark" type="file" accept=".jpg,.jpeg,.png,.pdf" />
                <span asp-validation-for="ProofFile" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex gap-3">
                <button class="btn btn-fit-green px-4" type="submit">Submit Deposit</button>
                <a asp-action="Index" class="btn-edit-profile">Back to Wallet</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
