@model WalletDashboardViewModel

@{
    ViewData["Title"] = "My Wallet";
}

<section class="container px-4 px-md-5 py-5">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <span class="eyebrow">Member Wallet</span>
            <h1 class="page-title mt-3">My Wallet</h1>
            <p class="text-secondary mb-0">Track your balance, deposits, and membership wallet payments.</p>
        </div>
        <div class="d-flex gap-3">
            <a asp-controller="Member" asp-action="TransferFunds" class="btn-edit-profile">Transfer Funds</a>
            <a asp-action="Deposit" class="btn btn-fit-green">Deposit Funds</a>
        </div>
    </div>

    @if (TempData["StatusMessage"] is string message)
    {
        <div class="alert alert-success">@message</div>
    }

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="panel-card stat-card stat-card-green">
                <span class="stat-label">Available Balance</span>
                <strong class="stat-value">@Model.Balance.ToString("C")</strong>
            </div>
        </div>
        <div class="col-md-6">
            <div class="panel-card stat-card stat-card-teal">
                <span class="stat-label">Approved Deposits</span>
                <strong class="stat-value">@Model.TotalDeposits.ToString("C")</strong>
            </div>
        </div>
    </div>

    <div class="panel-card">
        <h2 class="section-title">Wallet History</h2>
        <div class="table-responsive">
            <table class="table table-dark align-middle">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Amount</th>
                        <th>Method</th>
                        <th>Reference</th>
                        <th>Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentTransactions.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-secondary">No wallet activity yet.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var transaction in Model.RecentTransactions)
                        {
                            var badgeClass = transaction.Status switch
                            {
                                "Approved" => "badge-approved",
                                "Rejected" => "badge-rejected",
                                _ => "badge-pending"
                            };

                            <tr>
                                <td>@transaction.Type</td>
                                <td>@transaction.Amount.ToString("C")</td>
                                <td>@transaction.PaymentMethod</td>
                                <td>@(string.IsNullOrWhiteSpace(transaction.ReferenceNumber) ? "-" : transaction.ReferenceNumber)</td>
                                <td>@transaction.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                <td><span class="badge @badgeClass">@transaction.Status</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
